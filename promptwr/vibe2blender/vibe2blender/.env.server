# ─── Database Configuration ───────────────────────────────────────────
# Wasp defaults to PostgreSQL, but we use SQLite for local dev
DATABASE_URL="file:./dev.db"

# ─── Cloud AI (Gemini) ───────────────────────────────────────────────
# Required for script generation. Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Local AI (Ollama/Qwen) ─────────────────────────────────────────
# Ensure Ollama is running: `ollama serve`
# Ensure model is pulled: `ollama pull qwen2.5`
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5

FROM node:24-slim AS builder
WORKDIR /app
COPY . .
RUN npm install -g @wasp.sh/wasp-cli@latest
# Compile Wasp and generate standard Vite output
RUN wasp build
WORKDIR /app/.wasp/build/web-app
RUN npm install && npm run build

FROM nginx:alpine
COPY --from=builder /app/.wasp/build/web-app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
